# ═══════════════════════════════════════════════════
#  NEXACITY GLOBAL ENVIRONMENT TEMPLATE (.env.example)
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your actual credentials.

# --- FIREBASE CONFIGURATION (Shared by Web & Mobile) ---
# Get these from your Firebase Project Settings -> General -> Your apps
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_WEB_APP_ID

# Mobile (Duplicate for Expo public access)
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_WEB_APP_ID

# --- AI & INCIDENT DETECTION (Python Service) ---
# Get from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Twilio Configuration (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1234567890
TO_PHONE_NUMBER=+91XXXXXXXXXX

# Emergency Contacts
AMBULANCE_PHONE_NUMBER=+91XXXXXXXXXX
POLICE_PHONE_NUMBER=+91XXXXXXXXXX

# --- SYSTEM CONFIG ---
NODE_ENV=development
PORT=3000
AI_SERVICE_PORT=5005
